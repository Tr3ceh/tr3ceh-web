---
const { code, title, description, icon } = Astro.props;
---

<article
  class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition duration-300 hover:-translate-y-1 hover:border-cyan-400/30 hover:bg-white/[0.05]"
>
  <!-- Glow sutil -->
  <div
    class="pointer-events-none absolute inset-0 opacity-0 transition duration-500 group-hover:opacity-100"
  >
    <div class="absolute -inset-10 bg-cyan-400/10 blur-3xl"></div>
  </div>

  <div class="relative z-10">
    <!-- etiqueta técnica -->
    <div class="flex items-center justify-between">
      <span class="font-mono text-xs uppercase tracking-[0.2em] text-cyan-400">
        {code}
      </span>

      {icon && <span class="text-zinc-400">{icon}</span>}
    </div>

    <!-- título -->
    <h3 class="mt-4 text-xl font-semibold text-white">
      {title}
    </h3>

    <!-- descripción -->
    <p class="mt-3 leading-7 text-zinc-400">
      {description}
    </p>

    <!-- indicador -->
    <div
      class="mt-6 flex items-center text-sm text-cyan-300 opacity-0 transition duration-300 group-hover:opacity-100"
    >
      <span>Ver alcance</span>
      <span class="ml-2 transition-transform group-hover:translate-x-1">→</span>
    </div>
  </div>
</article>
