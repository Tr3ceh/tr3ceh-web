---
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<MainLayout
  title={`${post.data.title} | Tr3ceh`}
  description={post.data.description}
>
  <Navbar />

  <main class="mx-auto max-w-6xl px-6 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8 font-mono text-xs text-zinc-500" aria-label="Navegación">
      <a href="/blog" class="transition hover:text-cyan-400">Blog</a>
      <span class="mx-2">→</span>
      <span class="text-zinc-400">{post.data.title}</span>
    </nav>

    <div class="grid gap-12 lg:grid-cols-[1fr_260px]">
      <!-- Artículo principal -->
      <article>
        <!-- Cabecera del post -->
        <header class="mb-10">
          {
            post.data.tags && post.data.tags.length > 0 && (
              <div class="mb-4 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="rounded-full border border-cyan-400/15 bg-cyan-400/8 px-2.5 py-0.5 font-mono text-xs text-cyan-400">
                    {tag}
                  </span>
                ))}
              </div>
            )
          }

          <h1 class="text-3xl font-semibold tracking-tight text-white md:text-4xl">
            {post.data.title}
          </h1>

          <p class="mt-4 text-lg leading-8 text-zinc-400">
            {post.data.description}
          </p>

          <div class="mt-6 flex items-center gap-4 border-t border-white/10 pt-6">
            <div
              class="flex h-9 w-9 items-center justify-center rounded-xl border border-cyan-400/20 bg-cyan-400/10 text-xs font-semibold tracking-widest text-cyan-300"
            >
              T
            </div>
            <div>
              <p class="text-sm font-medium text-white">Tr3ceh</p>
              <time
                datetime={post.data.date.toISOString()}
                class="font-mono text-xs text-zinc-500"
              >
                {
                  post.data.date.toLocaleDateString("es-ES", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })
                }
              </time>
            </div>
          </div>
        </header>

        <!-- Contenido markdown -->
        <div class="prose">
          <Content />
        </div>

        <!-- Footer del artículo -->
        <div class="mt-16 border-t border-white/10 pt-8">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 font-mono text-sm text-zinc-500 transition hover:text-cyan-400"
          >
            ← Volver al blog
          </a>
        </div>
      </article>

      <!-- Sidebar: tabla de contenidos -->
      {
        headings.length > 0 && (
          <aside class="hidden lg:block">
            <div class="sticky top-24 rounded-2xl border border-white/10 bg-white/[0.03] p-6">
              <p class="mb-4 font-mono text-xs uppercase tracking-[0.2em] text-cyan-400">
                Contenido
              </p>
              <nav class="space-y-2">
                {headings.map((h) => (
                  <a
                    href={`#${h.slug}`}
                    class={`block text-sm transition hover:text-cyan-400 ${
                      h.depth === 2
                        ? "text-zinc-400"
                        : "pl-3 text-xs text-zinc-500"
                    }`}
                  >
                    {h.text}
                  </a>
                ))}
              </nav>
            </div>
          </aside>
        )
      }
    </div>
  </main>

  <Footer />
</MainLayout>
