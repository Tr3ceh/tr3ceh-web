---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ServiceCard from "../components/ServiceCard.astro";
---

<MainLayout
  title="Tr3ceh | Pentesting & Ciberseguridad"
  description="Servicios profesionales de pentesting, análisis de seguridad y consultoría en ciberseguridad."
>
  <Navbar />

  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden">
      <!-- Glow grid animado -->
      <div aria-hidden="true" class="pointer-events-none absolute inset-0">
        <div class="hero-grid absolute inset-0"></div>
        <div class="hero-scan absolute inset-0"></div>
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_45%,rgba(9,9,11,0.35)_100%)]"
        >
        </div>
      </div>

      <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
        <!-- Fila principal -->
        <div class="grid gap-12 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
          <!-- Columna izquierda -->
          <div class="max-w-3xl">
            <div
              class="inline-flex items-center gap-2 rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-xs font-medium uppercase tracking-[0.2em] text-cyan-300"
            >
              <span class="h-2 w-2 rounded-full bg-cyan-400"></span>
              Offensive Security · Pentesting
            </div>

            <div
              class="mt-6 inline-flex max-w-fit items-center rounded-xl border border-white/10 bg-black/20 px-4 py-2 font-mono text-sm text-zinc-300"
            >
              <span class="mr-3 text-cyan-400">$</span>
              security_assessment --target production
            </div>

            <h1
              class="mt-8 text-4xl font-semibold tracking-tight text-white md:text-6xl md:leading-tight"
            >
              Servicios de pentesting con un enfoque técnico, claro y
              profesional
            </h1>

            <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-400">
              Ayudo a identificar vulnerabilidades en aplicaciones, sistemas y
              entornos corporativos, aportando hallazgos reales, recomendaciones
              prácticas y una metodología orientada a mejorar la seguridad de
              forma práctica y accionable.
            </p>

            <div class="mt-10 flex flex-col gap-4 sm:flex-row">
              <a
                href="#contacto"
                class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-6 py-3 text-sm font-semibold text-zinc-950 transition duration-200 hover:-translate-y-0.5 hover:bg-cyan-300"
              >
                Solicitar auditoría
              </a>

              <a
                href="#servicios"
                class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/[0.03] px-6 py-3 text-sm font-semibold text-white transition duration-200 hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/5"
              >
                Ver servicios
              </a>
            </div>
          </div>

          <!-- Columna derecha -->
          <div class="relative">
            <div
              class="absolute -inset-6 rounded-[2rem] bg-cyan-400/10 blur-3xl"
            >
            </div>

            <div
              class="relative overflow-hidden rounded-3xl border border-white/10 bg-zinc-900/80 shadow-2xl backdrop-blur"
            >
              <div
                class="flex items-center justify-between border-b border-white/10 px-5 py-4"
              >
                <div class="flex items-center gap-2">
                  <span class="h-3 w-3 rounded-full bg-red-400/80"></span>
                  <span class="h-3 w-3 rounded-full bg-yellow-400/80"></span>
                  <span class="h-3 w-3 rounded-full bg-green-400/80"></span>
                </div>
                <p
                  class="font-mono text-xs uppercase tracking-[0.2em] text-zinc-500"
                >
                  Assessment Panel
                </p>
              </div>

              <div class="space-y-6 p-6">
                <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
                  <div class="flex items-center justify-between">
                    <p class="text-sm font-medium text-zinc-300">
                      Attack Surface Review
                    </p>
                    <span
                      class="rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2.5 py-1 text-xs font-medium text-cyan-300"
                    >
                      Active
                    </span>
                  </div>

                  <div class="mt-4 space-y-3 font-mono text-sm text-zinc-400">
                    <div class="flex items-center justify-between">
                      <span>subdomains_discovered</span>
                      <span class="text-white">12</span>
                    </div>
                    <div class="flex items-center justify-between">
                      <span>services_exposed</span>
                      <span class="text-white">7</span>
                    </div>
                    <div class="flex items-center justify-between">
                      <span>misconfigurations</span>
                      <span class="text-white">3</span>
                    </div>
                  </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div
                    class="rounded-2xl border border-white/10 bg-white/[0.03] p-4"
                  >
                    <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">
                      Critical
                    </p>
                    <p class="mt-3 text-3xl font-semibold text-white">01</p>
                  </div>

                  <div
                    class="rounded-2xl border border-white/10 bg-white/[0.03] p-4"
                  >
                    <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">
                      High
                    </p>
                    <p class="mt-3 text-3xl font-semibold text-white">02</p>
                  </div>

                  <div
                    class="rounded-2xl border border-white/10 bg-white/[0.03] p-4"
                  >
                    <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">
                      Medium
                    </p>
                    <p class="mt-3 text-3xl font-semibold text-white">04</p>
                  </div>

                  <div
                    class="rounded-2xl border border-white/10 bg-white/[0.03] p-4"
                  >
                    <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">
                      Low
                    </p>
                    <p class="mt-3 text-3xl font-semibold text-white">03</p>
                  </div>
                </div>

                <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
                  <div class="flex items-center justify-between">
                    <p class="text-sm font-medium text-zinc-300">
                      Security Score
                    </p>
                    <p class="font-mono text-sm text-cyan-300">
                      <span class="score-value" data-target="72">0</span> / 100
