          title="Pentesting Web"
          description="Evaluación de seguridad sobre aplicaciones web para detectar vulnerabilidades explotables y fallos de lógica."
        />

        <ServiceCard
          code="EXT-02"
          title="Attack Surface"
          description="Identificación de activos expuestos, subdominios, servicios accesibles y vectores de ataque visibles."
        />

        <ServiceCard
          code="CFG-03"
          title="Security Review"
          description="Análisis técnico de configuraciones, permisos, controles de acceso y servicios desplegados."
        />

        <ServiceCard
