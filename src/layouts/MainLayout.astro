---
import "../styles/global.css";

const {
  title = "Tr3ceh | Pentesting & Ciberseguridad",
  description = "Servicios de pentesting y ciberseguridad por Tr3ceh.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-zinc-950 text-zinc-100 antialiased">
    <div class="relative min-h-screen overflow-hidden">
      <!-- Grid sutil global -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 opacity-[0.06]"
        style="
          background-image:
            linear-gradient(to right, rgba(255,255,255,0.08) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(255,255,255,0.08) 1px, transparent 1px);
          background-size: 32px 32px;
          background-position: center;
        "
      >
      </div>

      <!-- Glow superior muy suave -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(34,211,238,0.08),transparent_35%)]"
      >
      </div>

      <!-- Contenido -->
      <div class="relative z-10">
        <slot />
      </div>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("reveal-visible");
              }
            });
          },
          { threshold: 0.15 },
        );

        document.querySelectorAll(".reveal").forEach((el) => {
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>
